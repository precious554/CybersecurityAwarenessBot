<Window x:Class="CybersecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Bot"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F0F4F8">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#1E3A5F"
                CornerRadius="0,0,10,10">

            <TextBlock Text="🛡 Cybersecurity Awareness Assistant"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Area -->
            <GroupBox Header="Chat"
                      Grid.Column="0"
                      Margin="5">

                <TextBox x:Name="ChatDisplay"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </GroupBox>

            <!-- Right Side -->
            <StackPanel Grid.Column="1" Margin="5">

                <GroupBox Header="Cybersecurity Tasks"
                          Height="250"
                          Margin="0,0,0,10">

                    <StackPanel>

                        <ListBox x:Name="TaskListBox"
                 Height="150"/>

                        <Button x:Name="CompleteTaskButton"
                Content="Mark Complete"
                Margin="5"
                Click="CompleteTaskButton_Click"/>

                        <Button x:Name="DeleteTaskButton"
                Content="Delete Task"
                Margin="5"
                Click="DeleteTaskButton_Click"/>

                    </StackPanel>

                </GroupBox>

                <GroupBox Header="Quiz Score"
                          Height="100"
                          Margin="0,0,0,10">

                    <TextBlock x:Name="ScoreText"
                               Text="Score: 0"
                               FontSize="20"
                               Margin="10"/>
                </GroupBox>

                <GroupBox Header="Activity Log">

                    <ListBox x:Name="ActivityLogList"/>
                </GroupBox>

            </StackPanel>

        </Grid>

        <!-- Bottom Input -->
        <Grid Grid.Row="2" Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                     Grid.Column="0"
                     Margin="0,0,10,0"
                     FontSize="14"/>

            <Button x:Name="SendButton"
        Grid.Column="1"
        Content="Send"
        FontSize="14"
        Click="SendButton_Click"/>
        </Grid>

    </Grid>
</Window>